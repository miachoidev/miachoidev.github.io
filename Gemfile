source "https://rubygems.org"
# gemspec
gem "jekyll", "~> 4.0"
gem "bundler", "~> 2.1"
gem "jekyll-paginate"
gem "jekyll-sitemap"
gem "jekyll-gist"
# 추가적인 플러그인들 (선택 사항)
gem "jekyll-seo-tag"        # SEO 태그 플러그인 (SEO 개선)
gem "jekyll-feed"           # RSS 피드 플러그인 (블로그에서 피드를 제공)
gem "jekyll-assets"         # CSS, JavaScript, 이미지 등 에셋 관리
gem "jekyll-scholar"        # 학술 논문 등 연구 자료를 관리할 때 유용한 플러그인
gem "jekyll-redirect-from"  # 리디렉션 플러그인 (옛 URL을 새 URL로 리디렉션)
gem 'jekyll-include-cache'

# 스타일링과 자바스크립트 관리에 유용한 gem들
gem "sassc"                 # Sass 컴파일
gem "uglifier"              # 자바스크립트 압축

gem "csv"
gem "base64"